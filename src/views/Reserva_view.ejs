<%- include('../components/header') %>

<main class="contenedor-lista">

<div class="encabezado-pagina">
<div style="display:flex; align-items:center; justify-content:space-between;">
  <h1 class="titulo-seccion"><%= mensaje %></h1>
  <button class="botonAgregar" onclick="abrirRegistro()">AGREGAR RESERVA</button>
</div>
<p class="subtitulo-seccion">
Gestión de ingresos y detalles de huéspedes - ADSO 2024
</p>
</div>

<div class="tabla-responsiva">

<table class="tabla-reservas">

<thead>
<tr>
<th>ID Reserva</th>
<th>Nombre Cliente</th>
<th>Tipo Habitación</th>
<th>Estado</th>
<th>Operaciones</th>
</tr>
</thead>

<tbody>

<% reservas.forEach((reserva,index)=>{ %>

<tr class="fila-reserva" style="<%= index >= 5 ? 'display:none;' : '' %>">

<td><strong><%= reserva.id_reserva %></strong></td>

<td><%= reserva.cliente.nombre %></td>

<td><%= reserva.detalles_estancia.tipo_habitacion %></td>

<td>

<span class="etiqueta-estado estado-<%= reserva.estado_reserva.toLowerCase() %>">
<%= reserva.estado_reserva %>
</span>

</td>

<td>

<button
class="boton-detalle"
data-reserva='<%- JSON.stringify(reserva) %>'
onclick="abrirModal(this)"
>
Editar
</button>

</td>

</tr>

<% }) %>

</tbody>
</table>

</div>

<div style="text-align:center;margin-top:20px">

<button id="btnMostrarMas" class="boton-detalle" onclick="mostrarMas()">
Mostrar más
</button>

</div>

</main>


<!-- MODAL ACTUALIZAR DATOS-->

<div id="miModal" class="ventana-modal">

<div class="contenido-modal">

<div class="modal-cabecera">

<h3>Editar Reserva</h3>

<span class="cerrar-modal" onclick="cerrarModal()">
&times;
</span>

</div>

<form method="POST" action="/reservas/update">

<input type="hidden" name="id_reserva" id="id_reserva">

<div id="detalleContenido" class="modal-cuerpo"></div>

<div style="margin-top:20px;text-align:right">

<button type="submit" class="boton-detalle">
Guardar cambios
</button>

</div>

</form>

</div>

</div>

<!-- MODAL AGREGAR RESERVA -->
<div id="registroModal" class="ventana-modal">
  <div class="contenido-modal">
    <div class="modal-cabecera">
      <h3>Añadir Reserva</h3>
      <span class="cerrar-modal" onclick="cerrarRegistro()">&times;</span>
    </div>

    <form method="POST" action="/reservas/create">
      <div class="modal-cuerpo">
        <div class="info-grupo">

          <label>Nombre</label>
          <input type="text" name="nombre" required>

          <label>Email</label>
          <input type="email" name="email" required>

          <label>Teléfono</label>
          <input type="text" name="telefono">

          <label>Tipo habitación</label>
          <select name="habitacion">
            <option>Suite</option>
            <option>Deluxe</option>
            <option>Junior Suite</option>
            <option>Individual</option>
          </select>

          <label>Número de huéspedes</label>
          <input type="number" name="num_huespedes" min="1" value="1" required>

        <label>Fecha de entrada</label>
        <input type="date" name="fecha_entrada" required>

        <label>Fecha de salida</label>
        <input type="date" name="fecha_salida" required>

        <label>Noches</label>
        <input type="number" name="noches" id="noches_registro" min="1" required>

        <label>Total</label>
        <input type="number" name="total" step="0.01" min="0" required>

        <label>Método de pago</label>
        <select name="metodo_pago">
        <option>Tarjeta de Crédito</option>
        <option>Tarjeta de Débito</option>
        <option>Efectivo</option>
        <option>Transferencia</option>
        </select>

        <label>Estado de pago</label>
        <select name="estado_pago">
        <option>Pendiente</option>
        <option>Pagado</option>
        <option>Reembolsado</option>
        </select>

          <label>Estado reserva</label>
          <select name="estado_reserva">
            <option>Confirmada</option>
            <option>Pendiente</option>
            <option>Cancelada</option>
            <option>Check-in</option>
          </select>

          <label>Notas</label>
          <textarea name="notas"></textarea>

        </div>
      </div>

      <div style="margin-top:20px; text-align:right">
        <button type="submit" class="boton-detalle">Guardar reserva</button>
      </div>
    </form>

  </div>
</div>



<%- include('../components/fotter') %>